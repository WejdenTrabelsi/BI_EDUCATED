# ── SQL Server connection ─────────────────────────────
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=educated-demo-db
DB_USER=your_username
DB_PASSWORD=your_password
DB_DRIVER=ODBC Driver 17 for SQL Server

# ── ETL settings ──────────────────────────────────────
ETL_BATCH_SIZE=500
ETL_LOG_LEVEL=INFO

# ── App settings ──────────────────────────────────────
APP_ENV=development
